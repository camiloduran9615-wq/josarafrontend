# ── API ──────────────────────────────────────────────────────────────────────
# Puerto donde el backend Laravel queda expuesto (Sail docker-compose: 8000->80)
VITE_API_TARGET=http://localhost:8000
# Prefijo de la API (debe coincidir con routes/tenant.php y routes/api.php)
VITE_API_BASE_URL=/api/v1

# ── Branding de Plataforma (single source of truth: backend config/platform.php)
# En runtime el frontend consume GET /api/platform. Estas variables son el
# fallback del build y alimentan el <title>/<meta> de index.html (%VITE_APP_*%).
# Para renombrar la plataforma cambia SOLO estas variables — no se toca código.
VITE_APP_NAME=JOSARA CLOUD
VITE_APP_SHORT_NAME=JOSARA
VITE_APP_TAGLINE=Confianza y precisión en cada número.
VITE_APP_DESCRIPTION=ERP Contable SaaS Multiempresa
VITE_APP_VERSION=1.0.0
